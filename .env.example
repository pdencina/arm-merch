# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://tu-proyecto.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=tu-anon-key

# Solo en servidor (nunca exponer al cliente)
SUPABASE_SERVICE_ROLE_KEY=tu-service-role-key

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=ARM Merch

# Resend (envío de emails)
# Crear cuenta gratis en resend.com → API Keys → Create API Key
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxx

# Email remitente (opcional)
# Sin dominio verificado: dejar vacío, usa onboarding@resend.dev
# Con dominio verificado en Resend: poner voucher@tudominio.cl
RESEND_FROM_EMAIL=

# SumUp Integration
SUMUP_CLIENT_ID=cc_classic_1X7QsMm52baVfvvBZPk7n6i3qP2HU
SUMUP_CLIENT_SECRET=tu_client_secret_aqui
SUMUP_MERCHANT_CODE=M0KP75HN
NEXT_PUBLIC_APP_URL=https://armerch-poud.vercel.app

# WhatsApp Business API (Meta)
WHATSAPP_TOKEN=tu_token_permanente_meta
WHATSAPP_PHONE_NUMBER_ID=tu_phone_number_id
WHATSAPP_VERIFY_TOKEN=un_string_secreto_para_webhook
WHATSAPP_GRAPH_API_VERSION=v22.0
WHATSAPP_TEMPLATE_LANGUAGE=es_CL

# Template para link de pago (opcional, si tienes uno aprobado en Meta)
WHATSAPP_TEMPLATE_LINK_PAGO=link_pago

# Template para notificación de pedido listo (opcional)
# Si no se configura, se envía como mensaje de texto libre
WHATSAPP_TEMPLATE_PEDIDO_LISTO=
